<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Miam{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.15em%22 font-size=%2290%22>🍽</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700&family=Fraunces:ital,opsz,wght@0,9..144,600;0,9..144,700;1,9..144,600&display=swap" rel="stylesheet">
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body class="app-body">
    <svg class="app-icon-sprite" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
        <symbol id="icon-calendar" viewBox="0 0 24 24">
            <path fill="currentColor" d="M7 2a1 1 0 0 1 1 1v1h8V3a1 1 0 1 1 2 0v1h1a3 3 0 0 1 3 3v2H2V7a3 3 0 0 1 3-3h1V3a1 1 0 0 1 1-1Zm15 9v8a3 3 0 0 1-3 3H5a3 3 0 0 1-3-3v-8h20Zm-6 3H8a1 1 0 1 0 0 2h8a1 1 0 1 0 0-2Z"/>
        </symbol>
        <symbol id="icon-book" viewBox="0 0 24 24">
            <path fill="currentColor" d="M5 3h12a3 3 0 0 1 3 3v13a1 1 0 0 1-1.447.894A7.1 7.1 0 0 0 15.5 19H6a3 3 0 0 1-3-3V5a2 2 0 0 1 2-2Zm1 4a1 1 0 0 0 0 2h10a1 1 0 1 0 0-2H6Zm0 4a1 1 0 0 0 0 2h10a1 1 0 1 0 0-2H6Z"/>
        </symbol>
        <symbol id="icon-upload" viewBox="0 0 24 24">
            <path fill="currentColor" d="M12 2a1 1 0 0 1 .707.293l4 4A1 1 0 1 1 15.293 7H13v7a1 1 0 1 1-2 0V7H8.707a1 1 0 0 1-.707-1.707l4-4A1 1 0 0 1 12 2Zm-7 13a1 1 0 0 1 1 1v2a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2v-2a1 1 0 1 1 2 0v2a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4v-2a1 1 0 0 1 1-1Z"/>
        </symbol>
        <symbol id="icon-plus" viewBox="0 0 24 24">
            <path fill="currentColor" d="M11 5a1 1 0 1 1 2 0v6h6a1 1 0 1 1 0 2h-6v6a1 1 0 1 1-2 0v-6H5a1 1 0 1 1 0-2h6V5Z"/>
        </symbol>
        <symbol id="icon-copy" viewBox="0 0 24 24">
            <path fill="currentColor" d="M8 3a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3V6a3 3 0 0 0-3-3H8Zm0 2h8a1 1 0 0 1 1 1v10a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm-4 4a1 1 0 0 1 1 1v10a1 1 0 0 0 1 1h8a1 1 0 1 1 0 2H6a3 3 0 0 1-3-3V10a1 1 0 0 1 1-1Z"/>
        </symbol>
        <symbol id="icon-trash" viewBox="0 0 24 24">
            <path fill="currentColor" d="M9 3a2 2 0 0 0-2 2v1H4a1 1 0 1 0 0 2h1v10a3 3 0 0 0 3 3h8a3 3 0 0 0 3-3V8h1a1 1 0 1 0 0-2h-3V5a2 2 0 0 0-2-2H9Zm0 3V5h6v1H9Zm-2 2h10v10a1 1 0 0 1-1 1H8a1 1 0 0 1-1-1V8Zm3 2a1 1 0 0 0-1 1v5a1 1 0 1 0 2 0v-5a1 1 0 0 0-1-1Zm4 0a1 1 0 0 0-1 1v5a1 1 0 1 0 2 0v-5a1 1 0 0 0-1-1Z"/>
        </symbol>
        <symbol id="icon-cart" viewBox="0 0 24 24">
            <path fill="currentColor" d="M3 4a1 1 0 0 1 1-1h1.2a2 2 0 0 1 1.94 1.515L7.5 6H20a1 1 0 0 1 .97 1.243l-1.5 6A2 2 0 0 1 17.53 15H9a2 2 0 0 1-1.94-1.515L5.26 6.3L5.2 6H4a1 1 0 0 1-1-1Zm5.74 4 .26 1h9.72l1-4H8.24ZM8 18a2 2 0 1 1 0 4a2 2 0 0 1 0-4Zm8 0a2 2 0 1 1 0 4a2 2 0 0 1 0-4Z"/>
        </symbol>
    </svg>
    {% set _route = app.request.attributes.get('_route', '') %}
    {% set is_planning = _route starts with 'app_planning' %}
    {% set nav_recipes_list = _route in ['app_recipe_index', 'app_recipe_new', 'app_recipe_edit', 'app_recipe_show'] %}
    {% set nav_recipe_import = _route == 'app_recipe_import' %}
    {% set nav_ingredients = _route starts with 'app_ingredient' %}

    <header class="app-header">
        <div class="app-header__inner">
            <a href="{{ path('app_planning_index') }}" class="app-brand" aria-label="Accueil Miam">
                <span class="app-brand__name">Miam</span>
                <span class="app-brand__tag">Famille</span>
            </a>
            <nav class="app-nav" aria-label="Navigation principale">
                <a href="{{ path('app_planning_index') }}" class="{{ is_planning ? 'is-active' : '' }}">
                    <svg class="app-icon" aria-hidden="true"><use href="#icon-calendar"></use></svg>
                    Planification
                </a>
                <a href="{{ path('app_recipe_index') }}" class="{{ nav_recipes_list ? 'is-active' : '' }}">
                    <svg class="app-icon" aria-hidden="true"><use href="#icon-book"></use></svg>
                    Recettes
                </a>
                <a href="{{ path('app_recipe_import') }}" class="{{ nav_recipe_import ? 'is-active' : '' }}">
                    <svg class="app-icon" aria-hidden="true"><use href="#icon-upload"></use></svg>
                    Importer
                </a>
                <a href="{{ path('app_ingredient_index') }}" class="{{ nav_ingredients ? 'is-active' : '' }}">
                    <svg class="app-icon" aria-hidden="true"><use href="#icon-book"></use></svg>
                    Ingrédients
                </a>
            </nav>
        </div>
    </header>

    <main class="app-main" id="main-content">
        {% block flashes %}
            {% for label, messages in app.flashes %}
                {% if loop.first %}
                    <div class="flash-stack" role="status" aria-live="polite">
                {% endif %}
                {% for message in messages %}
                    <div class="flash flash--{{
                        label == 'error' ? 'error' : (label == 'warning' ? 'warning' : 'success')
                    }}">{{ message }}</div>
                {% endfor %}
                {% if loop.last %}
                    </div>
                {% endif %}
            {% endfor %}
        {% endblock %}
        {% block body %}{% endblock %}
    </main>

    <footer class="app-footer">
        Miam — planification des repas
    </footer>

    {% block body_javascripts %}{% endblock %}
</body>
</html>
