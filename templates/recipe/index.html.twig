{% extends 'base.html.twig' %}

{% block title %}Recettes — Miam{% endblock %}

{% block body %}
    <h1 class="app-page-title">Recettes</h1>
    <p class="app-lead">La liste se met à jour pendant que tu tapes le nom ; les autres filtres utilisent « Appliquer ». Imports Jow, 750g et URL (schema.org) sur la page dédiée.</p>

    <div class="link-row">
        <a href="{{ path('app_planning_index') }}">← Planification</a>
        <a href="{{ path('app_recipe_import') }}">Importer (Jow, 750g, web…)</a>
        <a href="{{ path('app_recipe_new') }}">+ Nouvelle recette</a>
    </div>

    <div
        class="recipe-list-app"
        data-recipe-list-app
        data-fragment-url="{{ path('app_recipe_api_list_fragment') }}"
        data-index-path="{{ path('app_recipe_index') }}"
        data-plan-route-template="{{ path('app_recipe_plan', { id: '__RECIPE_ID__' }) }}"
        data-plan-available-slots="{{ availableSlotsByWeek|json_encode|e('html_attr') }}"
    >
    <div class="recipe-list-layout">
        <aside class="recipe-sidebar" aria-label="Filtres">
            <details
                id="recipe-filters-details"
                class="recipe-filters-details"
                data-recipe-filters-details
                data-initial-open="{{ hasActiveFilters ? '1' : '0' }}"
            >
                <summary class="recipe-filters-summary">
                    <span class="recipe-filters-summary__text">Filtres et tri</span>
                    <span class="recipe-filters-summary__hint muted">Afficher / masquer</span>
                </summary>
                <div class="card recipe-filters-card">
                    <h2 class="card__title recipe-filters-card__title">Filtres et tri</h2>
                    <form id="recipe-filters-form" method="get" action="{{ path('app_recipe_index') }}" class="stack-form">
                        <div class="form-grid form-grid--filters form-grid--sidebar-filters">
                            <div class="recipe-search">
                                <label class="recipe-search__label" for="filter-q">Nom de la recette</label>
                                <div class="recipe-search__shell">
                                    <span class="recipe-search__icon" aria-hidden="true">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false">
                                            <circle cx="11" cy="11" r="8"/>
                                            <path d="m21 21-4.3-4.3"/>
                                        </svg>
                                    </span>
                                    <input
                                        id="filter-q"
                                        class="recipe-search__input"
                                        type="search"
                                        name="q"
                                        value="{{ filters.q }}"
                                        placeholder="Ex. tarte, soupe, riz…"
                                        autocomplete="off"
                                        autocorrect="off"
                                        autocapitalize="off"
                                        spellcheck="false"
                                        enterkeyhint="search"
                                    >
                                </div>
                                <p class="recipe-search__hint muted">La liste se met à jour tout seul pendant la saisie.</p>
                            </div>
                            <div>
                                <label for="filter-main">Aliment principal</label>
                                <select id="filter-main" name="mainIngredient">
                                    <option value="">Tous</option>
                                    {% for label, value in mainIngredientChoices %}
                                        <option value="{{ value }}" {{ filters.mainIngredient == value ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label for="filter-season">Saison</label>
                                <select id="filter-season" name="seasonality">
                                    <option value="">Toutes</option>
                                    {% for label, value in seasonalityChoices %}
                                        <option value="{{ value }}" {{ filters.seasonality == value ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label for="filter-difficulty">Difficulté</label>
                                <select id="filter-difficulty" name="difficulty">
                                    <option value="">Toutes</option>
                                    {% for label, value in difficultyChoices %}
                                        <option value="{{ value }}" {{ filters.difficulty == value ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label for="filter-origin">Origine</label>
                                <select id="filter-origin" name="recipeOrigin">
                                    <option value="">Toutes</option>
                                    {% for label, value in recipeOriginChoices %}
                                        <option value="{{ value }}" {{ filters.recipeOrigin == value ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label for="filter-max-cost">Prix max (€)</label>
                                <input id="filter-max-cost" type="number" step="0.01" min="0" name="maxCost" value="{{ filters.maxCost ?? '' }}">
                            </div>
                            <div>
                                <label for="filter-max-calories">Calories max (kcal)</label>
                                <input id="filter-max-calories" type="number" min="0" step="10" name="maxCalories" value="{{ filters.maxCalories ?? '' }}">
                            </div>
                            <div>
                                <label for="filter-max-prep">Prépa max (min)</label>
                                <input id="filter-max-prep" type="number" min="0" step="5" name="maxPrep" value="{{ filters.maxPrep ?? '' }}">
                            </div>
                            <div>
                                <label for="filter-max-cook">Cuisson max (min)</label>
                                <input id="filter-max-cook" type="number" min="0" step="5" name="maxCook" value="{{ filters.maxCook ?? '' }}">
                            </div>
                            <div>
                                <label for="filter-max-total">Temps total max (min)</label>
                                <input id="filter-max-total" type="number" min="0" step="5" name="maxTotal" value="{{ filters.maxTotal ?? '' }}">
                            </div>
                            <div>
                                <label for="filter-sort">Trier par</label>
                                <select id="filter-sort" name="sort">
                                    {% for key, label in sortChoices %}
                                        <option value="{{ key }}" {{ filters.sort == key ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div>
                                <label for="filter-dir">Ordre</label>
                                <select id="filter-dir" name="dir">
                                    <option value="ASC" {{ filters.dir == 'ASC' ? 'selected' : '' }}>Croissant</option>
                                    <option value="DESC" {{ filters.dir == 'DESC' ? 'selected' : '' }}>Décroissant</option>
                                </select>
                            </div>
                        </div>
                        <p class="filter-actions">
                            <button type="submit" class="btn btn--primary">Appliquer</button>
                            <a href="{{ path('app_recipe_index') }}" class="btn btn--secondary" data-recipe-reset>Réinitialiser</a>
                        </p>
                    </form>
                </div>
            </details>
        </aside>

        <div class="recipe-list-main">
            <div id="recipe-results" class="recipe-results" data-recipe-results>
                {% include 'recipe/_list_main.html.twig' with {
                    recipes: recipes,
                    pagination: pagination,
                    filter_query: filter_query,
                    hasActiveFilters: hasActiveFilters
                } only %}
            </div>
        </div>
    </div>
    </div>

    <dialog
        class="recipe-plan-modal"
        data-recipe-plan-modal
        data-available-slots="{{ availableSlotsByWeek|json_encode|e('html_attr') }}"
        data-day-meals="{{ dayMealsByWeek|json_encode|e('html_attr') }}"
        data-weekdays="{{ weekdayChoices|json_encode|e('html_attr') }}"
    >
        <form method="post" class="card recipe-plan-modal__card" data-recipe-plan-form>
            <input type="hidden" name="_token" value="" data-recipe-plan-token>
            <header class="recipe-plan-modal__header">
                <h2 class="card__title">Ajouter à la planification</h2>
                <button type="button" class="btn btn--secondary btn--icon-only" data-recipe-plan-close aria-label="Fermer">×</button>
            </header>
            <p class="card__hint" data-recipe-plan-title>Recette</p>
            <p class="muted recipe-plan-modal__suggestion" data-recipe-plan-suggestion>{{ planningSuggestion.label }}</p>
            <div class="recipe-plan-form">
                <div>
                    <label for="modal_week_start">Planification</label>
                    <select id="modal_week_start" name="week_start" required data-recipe-plan-week>
                        {% for option in planningWeeks %}
                            <option value="{{ option.weekStart }}" {{ option.weekStart == planningSuggestion.weekStart ? 'selected' : '' }}>{{ option.label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div>
                    <label for="modal_slot_choice">Créneau actif libre</label>
                    {% set suggestedSlot = planningSuggestion.weekday ~ '|' ~ planningSuggestion.mealType %}
                    <select id="modal_slot_choice" name="slot_choice" required data-recipe-plan-slot>
                        {% for slot in availableSlotsByWeek[planningSuggestion.weekStart]|default([]) %}
                            <option
                                value="{{ slot.value }}"
                                data-readonly="{{ slot.readonly ? '1' : '0' }}"
                                {{ slot.value == suggestedSlot and not slot.readonly ? 'selected' : '' }}
                                {{ slot.readonly ? 'disabled' : '' }}
                            >
                                {{ slot.label }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <button type="submit" class="btn btn--primary">Ajouter</button>
            </div>
            <div class="recipe-plan-day-overview" data-recipe-plan-day-overview>
                <p class="muted" data-recipe-plan-day-title></p>
                <ul class="planning-related-list" data-recipe-plan-day-list></ul>
            </div>
        </form>
    </dialog>
{% endblock %}

{% block body_javascripts %}
    <script>
        (function () {
            var det = document.querySelector('[data-recipe-filters-details]');
            if (!det || typeof window.matchMedia !== 'function') {
                return;
            }
            var mq = window.matchMedia('(min-width: 960px)');
            var keepOpen = det.getAttribute('data-initial-open') === '1';

            function sync() {
                if (mq.matches) {
                    det.setAttribute('open', '');
                } else if (keepOpen) {
                    det.setAttribute('open', '');
                } else {
                    det.removeAttribute('open');
                }
            }

            mq.addEventListener('change', sync);
            sync();
        })();

        (function () {
            var modal = document.querySelector('[data-recipe-plan-modal]');
            if (!modal) {
                return;
            }
            var weekSelect = modal.querySelector('[data-recipe-plan-week]');
            var slotSelect = modal.querySelector('[data-recipe-plan-slot]');
            var dayTitle = modal.querySelector('[data-recipe-plan-day-title]');
            var dayList = modal.querySelector('[data-recipe-plan-day-list]');
            if (!weekSelect || !slotSelect) {
                return;
            }

            var slotsByWeek = {};
            var dayMealsByWeek = {};
            var weekdays = {};
            try {
                slotsByWeek = JSON.parse(modal.getAttribute('data-available-slots') || '{}');
            } catch (e) {
                slotsByWeek = {};
            }
            try {
                dayMealsByWeek = JSON.parse(modal.getAttribute('data-day-meals') || '{}');
            } catch (e) {
                dayMealsByWeek = {};
            }
            try {
                weekdays = JSON.parse(modal.getAttribute('data-weekdays') || '{}');
            } catch (e) {
                weekdays = {};
            }

            function selectedDay() {
                var raw = slotSelect.value || '';
                if (raw.indexOf('|') === -1) {
                    return '';
                }
                return raw.split('|')[0];
            }

            function renderDayOverview() {
                if (!dayTitle || !dayList) {
                    return;
                }
                var weekKey = weekSelect.value;
                var dayKey = selectedDay();
                dayList.innerHTML = '';
                if (!weekKey || !dayKey) {
                    dayTitle.textContent = '';
                    return;
                }

                var dayLabel = weekdays[dayKey] || ('Jour ' + dayKey);
                dayTitle.textContent = 'Repas déjà renseignés pour ' + dayLabel;

                var rows = (((dayMealsByWeek || {})[weekKey] || {})[dayKey] || []);
                if (!Array.isArray(rows) || rows.length === 0) {
                    var empty = document.createElement('li');
                    empty.className = 'planning-related-item';
                    empty.innerHTML = '<span class="muted">Aucun créneau actif sur ce jour.</span>';
                    dayList.appendChild(empty);
                    return;
                }

                rows.forEach(function (row) {
                    var li = document.createElement('li');
                    li.className = 'planning-related-item';
                    var mealLabel = row.mealLabel || row.mealType || 'Repas';
                    var recipeLabel = row.recipeName ? row.recipeName : 'Libre';
                    li.innerHTML = '<strong>' + mealLabel + '</strong><span class="muted"> — ' + recipeLabel + '</span>';
                    dayList.appendChild(li);
                });
            }

            function renderSlots() {
                var weekKey = weekSelect.value;
                var slots = slotsByWeek[weekKey] || [];
                var previous = slotSelect.value;
                slotSelect.innerHTML = '';

                if (!Array.isArray(slots) || slots.length === 0) {
                    var option = document.createElement('option');
                    option.value = '';
                    option.textContent = 'Aucun créneau libre pour cette planification';
                    slotSelect.appendChild(option);
                    slotSelect.value = '';
                    slotSelect.disabled = true;
                    renderDayOverview();
                    return;
                }

                var selectableValues = [];
                slots.forEach(function (slot) {
                    var option = document.createElement('option');
                    option.value = slot.value;
                    option.textContent = slot.label;
                     option.disabled = !!slot.readonly;
                    slotSelect.appendChild(option);
                    if (!slot.readonly) {
                        selectableValues.push(slot.value);
                    }
                });

                if (selectableValues.length === 0) {
                    slotSelect.value = '';
                    slotSelect.disabled = true;
                    renderDayOverview();
                    return;
                }

                slotSelect.disabled = false;
                var stillExists = selectableValues.indexOf(previous) !== -1;
                slotSelect.value = stillExists ? previous : selectableValues[0];
                renderDayOverview();
            }

            weekSelect.addEventListener('change', renderSlots);
            slotSelect.addEventListener('change', renderDayOverview);
            modal.addEventListener('close', renderSlots);
            renderSlots();
        })();
    </script>
{% endblock %}
